<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WikiPicture Report</title>
<style>
  :root {
    --green: #2e7d32;
    --yellow: #f9a825;
    --orange: #e65100;
    --red: #c62828;
    --bg-green: #e8f5e9;
    --bg-yellow: #fffde7;
    --bg-red: #ffebee;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; color: #212121; background: #fafafa; line-height: 1.5; }
  .container { max-width: 1400px; margin: 0 auto; padding: 1rem; }

  header { background: linear-gradient(135deg, #1565c0, #0d47a1); color: #fff; padding: 2rem 0; margin-bottom: 1.5rem; }
  header .container { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1rem; }
  header h1 { font-size: 1.8rem; }
  header .date { opacity: .85; font-size: .9rem; }

  .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
  .stat-card { background: #fff; border-radius: 8px; padding: 1.2rem; box-shadow: 0 1px 3px rgba(0,0,0,.12); text-align: center; }
  .stat-card .value { font-size: 2rem; font-weight: 700; color: #1565c0; }
  .stat-card .label { font-size: .85rem; color: #757575; margin-top: .25rem; }

  table { width: 100%; border-collapse: collapse; background: #fff; box-shadow: 0 1px 3px rgba(0,0,0,.12); border-radius: 8px; overflow: hidden; }
  th, td { padding: .6rem .75rem; text-align: left; border-bottom: 1px solid #e0e0e0; font-size: .875rem; }
  th { background: #f5f5f5; cursor: pointer; user-select: none; position: sticky; top: 0; white-space: nowrap; }
  th:hover { background: #e0e0e0; }
  th .sort-arrow { margin-left: 4px; font-size: .7rem; opacity: .5; }
  th.sorted-asc .sort-arrow::after { content: "▲"; opacity: 1; }
  th.sorted-desc .sort-arrow::after { content: "▼"; opacity: 1; }

  .thumb { width: 80px; height: 80px; object-fit: cover; border-radius: 4px; display: block; background: #eee; }

  .score-bar { display: inline-flex; align-items: center; gap: 6px; }
  .score-bar .bar { height: 10px; border-radius: 5px; min-width: 10px; }
  .score-bar .num { font-weight: 600; font-size: .85rem; }

  .score-green  .bar { background: var(--green); }
  .score-green  .num { color: var(--green); }
  .score-yellow .bar { background: var(--yellow); }
  .score-yellow .num { color: #f57f17; }
  .score-orange .bar { background: var(--orange); }
  .score-orange .num { color: var(--orange); }
  .score-red    .bar { background: var(--red); }
  .score-red    .num { color: var(--red); }

  .row-highly-recommended { background: var(--bg-green); }
  .row-recommended { background: var(--bg-yellow); }
  .row-not-recommended { background: var(--bg-red); }

  td ul { margin: 0; padding-left: 1.1rem; }
  td ul li { font-size: .8rem; color: #616161; }
  a { color: #1565c0; text-decoration: none; }
  a:hover { text-decoration: underline; }

  footer { text-align: center; padding: 2rem 0 1rem; color: #9e9e9e; font-size: .8rem; }

  @media (max-width: 900px) {
    .table-wrap { overflow-x: auto; }
    th, td { white-space: nowrap; }
  }
</style>
</head>
<body>

<header>
  <div class="container">
    <div>
      <h1>📸 WikiPicture Report</h1>
      <div class="date">Generated {{ generated_at }}</div>
    </div>
  </div>
</header>

<div class="container">
  <div class="stats">
    <div class="stat-card">
      <div class="value">{{ total_photos }}</div>
      <div class="label">Photos Scanned</div>
    </div>
    <div class="stat-card">
      <div class="value">{{ photos_with_gps }}</div>
      <div class="label">Photos with GPS</div>
    </div>
    <div class="stat-card">
      <div class="value">{{ unique_locations }}</div>
      <div class="label">Unique Locations</div>
    </div>
    <div class="stat-card">
      <div class="value">{{ opportunities | length }}</div>
      <div class="label">Top Opportunities</div>
    </div>
  </div>

  <div class="table-wrap">
    <table id="report-table">
      <thead>
        <tr>
          <th data-col="0">Thumbnail <span class="sort-arrow"></span></th>
          <th data-col="1">Location <span class="sort-arrow"></span></th>
          <th data-col="2" data-type="number">Score <span class="sort-arrow"></span></th>
          <th data-col="3">Recommendation <span class="sort-arrow"></span></th>
          <th data-col="4">Wikipedia Article <span class="sort-arrow"></span></th>
          <th data-col="5" data-type="number">Article Images <span class="sort-arrow"></span></th>
          <th data-col="6">Commons Saturation <span class="sort-arrow"></span></th>
          <th data-col="7">Key Reasons <span class="sort-arrow"></span></th>
        </tr>
      </thead>
      <tbody>
        {% for opp in opportunities %}
        {% set rec_lower = opp.recommendation | lower %}
        <tr class="{% if 'highly' in rec_lower %}row-highly-recommended{% elif 'not' in rec_lower %}row-not-recommended{% elif 'recommended' in rec_lower %}row-recommended{% endif %}">
          <td><img class="thumb" src="file:///{{ opp.filepath | string | replace('\\', '/') }}" alt="photo" loading="lazy"></td>
          <td>{{ opp.location_name }}</td>
          <td data-value="{{ '%.1f' | format(opp.score) }}">
            {% if opp.score >= 70 %}
              {% set sclass = "score-green" %}
            {% elif opp.score >= 45 %}
              {% set sclass = "score-yellow" %}
            {% elif opp.score >= 25 %}
              {% set sclass = "score-orange" %}
            {% else %}
              {% set sclass = "score-red" %}
            {% endif %}
            <span class="score-bar {{ sclass }}">
              <span class="bar" style="width:{{ opp.score }}px"></span>
              <span class="num">{{ '%.1f' | format(opp.score) }}</span>
            </span>
          </td>
          <td>{{ opp.recommendation }}</td>
          <td>
            {% if opp.best_article %}
              <a href="{{ opp.best_article.url }}" target="_blank" rel="noopener">{{ opp.best_article.title }}</a>
            {% else %}
              <span style="color:#9e9e9e">No article found</span>
            {% endif %}
          </td>
          <td data-value="{{ opp.best_article.image_count if opp.best_article else 0 }}">
            {{ opp.best_article.image_count if opp.best_article else "—" }}
          </td>
          <td>
            {% if opp.commons_result %}
              {{ opp.commons_result.saturation.value }} ({{ opp.commons_result.nearby_image_count }} nearby)
            {% else %}
              —
            {% endif %}
          </td>
          <td>
            {% if opp.reasons %}
            <ul>
              {% for reason in opp.reasons %}
              <li>{{ reason }}</li>
              {% endfor %}
            </ul>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<footer>
  <div class="container">WikiPicture — Find Wikipedia articles that need your photos</div>
</footer>

<script>
(function(){
  const table = document.getElementById("report-table");
  const headers = table.querySelectorAll("th");
  let currentCol = -1;
  let asc = true;

  headers.forEach(th => {
    th.addEventListener("click", function(){
      const col = parseInt(this.dataset.col);
      const isNum = this.dataset.type === "number";
      if(currentCol === col){ asc = !asc; } else { asc = true; currentCol = col; }

      headers.forEach(h => h.classList.remove("sorted-asc","sorted-desc"));
      this.classList.add(asc ? "sorted-asc" : "sorted-desc");

      const tbody = table.querySelector("tbody");
      const rows = Array.from(tbody.querySelectorAll("tr"));
      rows.sort((a, b) => {
        const cellA = a.children[col];
        const cellB = b.children[col];
        let va = cellA.dataset.value !== undefined ? cellA.dataset.value : cellA.textContent.trim();
        let vb = cellB.dataset.value !== undefined ? cellB.dataset.value : cellB.textContent.trim();
        if(isNum){ va = parseFloat(va) || 0; vb = parseFloat(vb) || 0; return asc ? va - vb : vb - va; }
        return asc ? va.localeCompare(vb) : vb.localeCompare(va);
      });
      rows.forEach(r => tbody.appendChild(r));
    });
  });
})();
</script>

</body>
</html>
